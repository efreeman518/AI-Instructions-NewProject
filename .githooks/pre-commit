#!/usr/bin/env bash
# Pre-commit hook: regenerate manifest and phase-load-packs when instruction files change.
# Install: git config core.hooksPath .githooks

# Check if any instruction .md, .json (non-phase-load-packs), or script files are staged
STAGED_INSTRUCTION_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|ps1)$|_manifest\.json$' | grep -v 'phase-load-packs.json' | grep -v 'sample-app/')

if [ -z "$STAGED_INSTRUCTION_FILES" ]; then
    exit 0
fi

echo "[pre-commit] Instruction files changed — regenerating manifest and load packs..."

# Check if PowerShell is available
if command -v pwsh &> /dev/null; then
    PWSH=pwsh
elif command -v powershell &> /dev/null; then
    PWSH=powershell
else
    echo "[pre-commit] WARNING: PowerShell not found. Skipping manifest regeneration."
    echo "[pre-commit] Run scripts/preflight-instructions.ps1 manually before pushing."
    exit 0
fi

# Run manifest update and phase-load-packs generation
$PWSH -NoProfile -ExecutionPolicy Bypass -File scripts/update-manifest.ps1 2>/dev/null
$PWSH -NoProfile -ExecutionPolicy Bypass -File scripts/generate-phase-load-packs.ps1 2>/dev/null

# Stage the regenerated files if they changed
git add _manifest.json phase-load-packs.json 2>/dev/null

echo "[pre-commit] Manifest and load packs updated."
