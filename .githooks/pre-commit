#!/usr/bin/env bash
# Pre-commit hook: regenerate manifest and phase-load-packs when instruction files change.
# Install: git config core.hooksPath .githooks

# Check if any instruction .md or manifest files are staged
STAGED_INSTRUCTION_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$|_manifest\.json$' | grep -v 'phase-load-packs.json')

if [ -z "$STAGED_INSTRUCTION_FILES" ]; then
    exit 0
fi

echo "[pre-commit] Instruction files changed — regenerating manifest and load packs..."

# Locate Python (prefer `python`, fall back to `py` on Windows)
if command -v python &> /dev/null; then
    PY="python"
elif command -v py &> /dev/null; then
    PY="py -3"
else
    echo "[pre-commit] WARNING: Python not found. Skipping manifest regeneration."
    echo "[pre-commit] Run scripts/preflight-instructions.py manually before pushing."
    exit 0
fi

$PY scripts/update-manifest.py 2>/dev/null
$PY scripts/generate-phase-load-packs.py 2>/dev/null

# Stage the regenerated files if they changed
git add _manifest.json phase-load-packs.json 2>/dev/null

echo "[pre-commit] Manifest and load packs updated."
