{
  // ═══════════════════════════════════════════════════════════════
  // Pattern: Gateway appsettings.json — YARP routes/clusters + auth config.
  // YARP loads from the "ReverseProxy" section.
  // Aspire service discovery resolves cluster destinations at runtime
  // (e.g., "https+http://taskflowapi" → actual endpoint address).
  // ═══════════════════════════════════════════════════════════════

  "AppName": "TaskFlow.Gateway",

  // ═══════════════════════════════════════════════════════════════
  // YARP Reverse Proxy — Routes + Clusters
  // Pattern: Routes map incoming paths to clusters.
  //          Clusters define backend destinations with load balancing.
  //          Service discovery resolves Aspire-injected endpoints.
  // ═══════════════════════════════════════════════════════════════

  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "Metadata": {
          "AuthorizationPolicy": "Default"
        }
      },
      "scheduler-route": {
        "ClusterId": "scheduler-cluster",
        "Match": {
          "Path": "scheduler/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/scheduler" }
        ],
        "Metadata": {
          "AuthorizationPolicy": "AdminPolicy"
        }
      },
      "health-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "health/{**catch-all}"
        },
        "Metadata": {
          "AuthorizationPolicy": "Anonymous"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api-primary": {
            "Address": "https+http://taskflowapi"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Path": "/alive"
          }
        },
        "LoadBalancingPolicy": "RoundRobin"
      },
      "scheduler-cluster": {
        "Destinations": {
          "scheduler-primary": {
            "Address": "https+http://taskflowscheduler"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Path": "/alive"
          }
        }
      }
    }
  },

  // ═══════════════════════════════════════════════════════════════
  // Pattern: User-facing authentication — Entra External ID (B2C-like).
  // Gateway authenticates external users; then relays claims downstream.
  // ═══════════════════════════════════════════════════════════════

  "Gateway_EntraExt": {
    "Instance": "https://{tenant}.ciamlogin.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": "",
    "SignUpSignInPolicyId": ""
  },

  // ═══════════════════════════════════════════════════════════════
  // Pattern: Service-to-service auth — client credential flow.
  // Gateway acquires a token for downstream APIs using its own identity.
  // ═══════════════════════════════════════════════════════════════

  "ServiceAuth": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "Scopes": {
      "api-cluster": "api://{api-client-id}/.default",
      "scheduler-cluster": "api://{scheduler-client-id}/.default"
    }
  },

  // ═══════════════════════════════════════════════════════════════
  // Pattern: CORS — allow frontend origins.
  // ═══════════════════════════════════════════════════════════════

  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5000",
      "https://localhost:5173"
    ]
  },

  // Pattern: Health checks — aggregate downstream health.
  "HealthChecks": {
    "DownstreamEndpoints": [
      "https+http://taskflowapi/alive",
      "https+http://taskflowscheduler/alive"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  }
}
