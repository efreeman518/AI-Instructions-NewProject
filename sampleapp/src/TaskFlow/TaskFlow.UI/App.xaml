<!-- Pattern: App.xaml — application-level resources and Material theme merging.
     ColorPaletteOverride.xaml provides Material Design 3 color customization.
     All ResourceDictionaries are merged here to be available app-wide. -->
<Application x:Class="TaskFlow.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Uno Material Theme with color palette overrides -->
                <MaterialTheme ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml" />
                <ToolkitResources />
                <MaterialToolkitResources />
                <!-- App-level converters -->
                <ResourceDictionary Source="ms-appx:///Converters/Converters.xaml" />
                <!-- Control style overrides -->
                <ResourceDictionary Source="ms-appx:///Styles/FeedView.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
