<!-- ═══════════════════════════════════════════════════════════════
     Pattern: Converters ResourceDictionary — merges all IValueConverter instances.
     Referenced in App.xaml via MergedDictionaries so converters are available app-wide.
     
     Individual converters are declared as static resources here and referenced
     in XAML via {StaticResource ConverterName}.
     ═══════════════════════════════════════════════════════════════ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:TaskFlow.UI.Converters">

    <!-- Pattern: IValueConverter instances as static resources — referenced in Binding expressions.
         Usage: Converter={StaticResource StringFormatConverter}, ConverterParameter='Due: {0:d}' -->
    <converters:StringFormatConverter x:Key="StringFormatConverter" />
    <converters:BoolInverterConverter x:Key="BoolInverterConverter" />

</ResourceDictionary>
