<!-- ═══════════════════════════════════════════════════════════════
     Pattern: ColorPaletteOverride — Material Design 3 color customization.
     Overrides the default Material color palette for app-wide branding.
     Referenced in App.xaml via MaterialTheme ColorOverrideSource.
     
     Colors follow the Material Design 3 color roles:
     - Primary: main action buttons, FABs, active states
     - Secondary: less prominent components
     - Tertiary: contrasting accents
     - Error: validation and error states
     - Surface: backgrounds, cards, sheets
     ═══════════════════════════════════════════════════════════════ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pattern: Light theme color overrides -->
    <Color x:Key="PrimaryColor">#FF6750A4</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="PrimaryContainerColor">#FFEADDFF</Color>
    <Color x:Key="OnPrimaryContainerColor">#FF21005D</Color>

    <Color x:Key="SecondaryColor">#FF625B71</Color>
    <Color x:Key="OnSecondaryColor">#FFFFFFFF</Color>
    <Color x:Key="SecondaryContainerColor">#FFE8DEF8</Color>
    <Color x:Key="OnSecondaryContainerColor">#FF1D192B</Color>

    <Color x:Key="TertiaryColor">#FF7D5260</Color>
    <Color x:Key="OnTertiaryColor">#FFFFFFFF</Color>
    <Color x:Key="TertiaryContainerColor">#FFFFD8E4</Color>
    <Color x:Key="OnTertiaryContainerColor">#FF31111D</Color>

    <Color x:Key="ErrorColor">#FFB3261E</Color>
    <Color x:Key="OnErrorColor">#FFFFFFFF</Color>
    <Color x:Key="ErrorContainerColor">#FFF9DEDC</Color>
    <Color x:Key="OnErrorContainerColor">#FF410E0B</Color>

    <Color x:Key="BackgroundColor">#FFFFFBFE</Color>
    <Color x:Key="OnBackgroundColor">#FF1C1B1F</Color>
    <Color x:Key="SurfaceColor">#FFFFFBFE</Color>
    <Color x:Key="OnSurfaceColor">#FF1C1B1F</Color>
    <Color x:Key="SurfaceVariantColor">#FFE7E0EC</Color>
    <Color x:Key="OnSurfaceVariantColor">#FF49454F</Color>

    <Color x:Key="OutlineColor">#FF79747E</Color>
    <Color x:Key="OutlineVariantColor">#FFCAC4D0</Color>

    <!-- Pattern: Dark theme overrides would go in a separate ThemeDictionary -->
    <!-- For complete dark theme support, wrap in ResourceDictionary.ThemeDictionaries -->

</ResourceDictionary>
