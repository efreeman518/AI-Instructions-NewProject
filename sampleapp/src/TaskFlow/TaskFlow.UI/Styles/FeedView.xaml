<!-- ═══════════════════════════════════════════════════════════════
     Pattern: FeedView style override — default loading/error visual states.
     Referenced in App.xaml via merged ResourceDictionary.
     
     FeedView from Uno.Toolkit wraps async data with three visual states:
     - Loading: ProgressRing centered in the container
     - Error: Error message with retry button
     - Data: Content rendered by ValueTemplate (set per-page)
     
     These defaults apply globally; individual pages customize ValueTemplate.
     ═══════════════════════════════════════════════════════════════ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:utu="using:Uno.Toolkit.UI">

    <!-- Pattern: Default FeedView Style — applied to all FeedView instances unless overridden. -->
    <Style TargetType="utu:FeedView">

        <!-- Pattern: ProgressTemplate — shown while IFeed/IListFeed is in Loading state. -->
        <Setter Property="ProgressTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Padding="24">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="12">
                            <ProgressRing IsActive="True"
                                          Width="48"
                                          Height="48" />
                            <TextBlock Text="Loading..."
                                       Style="{StaticResource BodyMediumTextBlockStyle}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <!-- Pattern: ErrorTemplate — shown when IFeed/IListFeed enters Error state. -->
        <Setter Property="ErrorTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Padding="24">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="12">
                            <FontIcon Glyph="&#xE7BA;"
                                      FontSize="48"
                                      Foreground="{ThemeResource ErrorColor}" />
                            <TextBlock Text="Something went wrong"
                                       Style="{StaticResource BodyLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6"
                                       TextWrapping="Wrap"
                                       MaxWidth="300" />
                            <Button Content="Retry"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource OutlinedButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <!-- Pattern: NoneTemplate — shown when IListFeed returns an empty collection. -->
        <Setter Property="NoneTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Padding="24">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE8B7;"
                                      FontSize="48"
                                      Opacity="0.3" />
                            <TextBlock Text="No items found"
                                       Style="{StaticResource BodyLargeTextBlockStyle}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.5" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>
</ResourceDictionary>
