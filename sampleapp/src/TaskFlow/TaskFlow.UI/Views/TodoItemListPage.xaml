<!-- ═══════════════════════════════════════════════════════════════
     Pattern: TodoItemListPage — FeedView-wrapped list with search and FAB.
     
     Key MVUX XAML binding patterns:
     1. FeedView wraps async data — handles Loading, Error, Data states
     2. TextBox binds two-way to SearchTerm IState
     3. ListView.ItemsSource binds to FilteredItems IListState
     4. Command bindings invoke public ValueTask methods on the model
     5. DataTemplate binds to TodoItem record properties
     ═══════════════════════════════════════════════════════════════ -->
<Page x:Class="TaskFlow.UI.Views.TodoItemListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:TaskFlow.UI.Business.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Pattern: Page header with create button. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Todo Items"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- Pattern: Command binding — Create is a public ValueTask on TodoItemListModel.
                 MVUX source generator creates ICommand automatically. -->
            <Button Grid.Column="1"
                    Content="+ New"
                    Command="{Binding Create}"
                    Style="{StaticResource FilledButtonStyle}" />
        </Grid>

        <!-- Pattern: Two-way binding to IState<string> — search filter.
             Updates trigger Feed.Combine re-evaluation in the model. -->
        <TextBox Grid.Row="1"
                 PlaceholderText="Search tasks..."
                 Text="{Binding SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />

        <!-- Pattern: FeedView — wraps async list data with loading/error/data visual states.
             Source binds to IListState<TodoItem> which combines search + feed. -->
        <utu:FeedView Grid.Row="2"
                      Source="{Binding FilteredItems}">

            <!-- Pattern: FeedView.ValueTemplate — rendered when data is available. -->
            <utu:FeedView.ValueTemplate>
                <DataTemplate>
                    <ListView ItemsSource="{Binding Data}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:TodoItem">
                                <Grid Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Pattern: CheckBox bound to completion toggle command.
                                         Command passes the current item for toggle. -->
                                    <CheckBox Grid.Column="0" Grid.RowSpan="2"
                                              IsChecked="{x:Bind IsCompleted}"
                                              VerticalAlignment="Center" />

                                    <!-- Pattern: Tappable area for navigation to detail. -->
                                    <TextBlock Grid.Column="1" Grid.Row="0"
                                               Text="{x:Bind Title}"
                                               Style="{StaticResource BodyLargeTextBlockStyle}"
                                               TextDecorations="{x:Bind IsCompleted}" />

                                    <StackPanel Grid.Column="1" Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{x:Bind DisplayPriority}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{x:Bind CategoryName}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.5" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Grid.RowSpan="2"
                                               Text="{x:Bind DisplayStatus}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DataTemplate>
            </utu:FeedView.ValueTemplate>

            <!-- Pattern: FeedView.ProgressTemplate — shown while loading. -->
            <utu:FeedView.ProgressTemplate>
                <DataTemplate>
                    <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </DataTemplate>
            </utu:FeedView.ProgressTemplate>

            <!-- Pattern: FeedView.ErrorTemplate — shown on error. -->
            <utu:FeedView.ErrorTemplate>
                <DataTemplate>
                    <TextBlock Text="Failed to load items. Please try again."
                               Foreground="{ThemeResource SystemErrorTextColor}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </DataTemplate>
            </utu:FeedView.ErrorTemplate>

            <!-- Pattern: FeedView.NoneTemplate — shown when list is empty. -->
            <utu:FeedView.NoneTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <FontIcon Glyph="&#xE762;"
                                  FontSize="48"
                                  Opacity="0.4" />
                        <TextBlock Text="No tasks found"
                                   Style="{StaticResource BodyLargeTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   Opacity="0.6" />
                    </StackPanel>
                </DataTemplate>
            </utu:FeedView.NoneTemplate>
        </utu:FeedView>
    </Grid>
</Page>
