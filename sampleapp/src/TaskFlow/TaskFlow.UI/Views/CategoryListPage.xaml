<!-- ═══════════════════════════════════════════════════════════════
     Pattern: CategoryListPage — simple list with FeedView and .Observe() auto-refresh.
     
     Demonstrates simpler list pattern for cacheable/static entities.
     No search or filtering — just a straight FeedView wrapping IListState.
     ═══════════════════════════════════════════════════════════════ -->
<Page x:Class="TaskFlow.UI.Views.CategoryListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:TaskFlow.UI.Business.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Categories"
                   Style="{StaticResource TitleLargeTextBlockStyle}"
                   Margin="0,0,0,12" />

        <!-- Pattern: FeedView wraps IListState<Category> — handles all async states. -->
        <utu:FeedView Grid.Row="1"
                      Source="{Binding ObservableItems}">

            <utu:FeedView.ValueTemplate>
                <DataTemplate>
                    <ListView ItemsSource="{Binding Data}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:Category">
                                <Grid Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0" Grid.Row="0"
                                               Text="{x:Bind Name}"
                                               Style="{StaticResource BodyLargeTextBlockStyle}" />

                                    <TextBlock Grid.Column="0" Grid.Row="1"
                                               Text="{x:Bind Description}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.6" />

                                    <Border Grid.Column="1" Grid.RowSpan="2"
                                            VerticalAlignment="Center"
                                            CornerRadius="12"
                                            Padding="8,4"
                                            Background="{ThemeResource SystemAccentColorBrush}"
                                            Visibility="{x:Bind IsActive}">
                                        <TextBlock Text="Active"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="White" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DataTemplate>
            </utu:FeedView.ValueTemplate>

            <utu:FeedView.ProgressTemplate>
                <DataTemplate>
                    <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </DataTemplate>
            </utu:FeedView.ProgressTemplate>

            <utu:FeedView.NoneTemplate>
                <DataTemplate>
                    <TextBlock Text="No categories available"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.6" />
                </DataTemplate>
            </utu:FeedView.NoneTemplate>
        </utu:FeedView>
    </Grid>
</Page>
