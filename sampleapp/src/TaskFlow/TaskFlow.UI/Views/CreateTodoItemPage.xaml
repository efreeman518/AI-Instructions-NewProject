<!-- ═══════════════════════════════════════════════════════════════
     Pattern: CreateTodoItemPage — form-based entity creation.
     
     Key patterns:
     1. TextBox binds two-way to IState<string> (Title, Description)
     2. NumberBox binds two-way to IState<int> (Priority)
     3. ComboBox binds ItemsSource to IListFeed<Category>, selection to IState<Category?>
     4. Save/Cancel buttons bind to auto-generated commands
     ═══════════════════════════════════════════════════════════════ -->
<Page x:Class="TaskFlow.UI.Views.CreateTodoItemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:TaskFlow.UI.Business.Models">

    <ScrollViewer>
        <StackPanel Padding="16"
                    Spacing="16"
                    MaxWidth="600"
                    HorizontalAlignment="Stretch">

            <TextBlock Text="Create New Task"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- Pattern: Form field — two-way bind to IState<string> Title. -->
            <TextBox Header="Title"
                     PlaceholderText="Enter task title"
                     Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Pattern: Form field — multi-line description. -->
            <TextBox Header="Description"
                     PlaceholderText="Enter description"
                     Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="100" />

            <!-- Pattern: NumberBox for integer IState — priority selection. -->
            <NumberBox Header="Priority (1-4)"
                       Value="{Binding Priority, Mode=TwoWay}"
                       Minimum="1"
                       Maximum="4"
                       SpinButtonPlacementMode="Inline" />

            <!-- Pattern: ComboBox binding to IListFeed<Category> for dropdown data.
                 ItemsSource wraps the feed in FeedView; SelectedItem binds to IState<Category?>. -->
            <utu:FeedView Source="{Binding Categories}">
                <utu:FeedView.ValueTemplate>
                    <DataTemplate>
                        <ComboBox Header="Category"
                                  ItemsSource="{Binding Data}"
                                  SelectedItem="{Binding Data.SelectedCategory, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Stretch" />
                    </DataTemplate>
                </utu:FeedView.ValueTemplate>
                <utu:FeedView.ProgressTemplate>
                    <DataTemplate>
                        <ProgressRing IsActive="True" Width="24" Height="24" />
                    </DataTemplate>
                </utu:FeedView.ProgressTemplate>
            </utu:FeedView>

            <!-- Pattern: Action buttons — Save validates + creates, Cancel navigates back. -->
            <Grid ColumnSpacing="12"
                  Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding Cancel}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource OutlinedButtonStyle}" />

                <Button Grid.Column="1"
                        Content="Save"
                        Command="{Binding Save}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource FilledButtonStyle}" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
