<!-- Pattern: Shell — top-level navigation host providing TabBar + NavigationBar.
     Uses Uno Toolkit's TabBar for main section navigation (TodoItems, Categories, Settings).
     The TabBar items navigate to named routes registered in App.xaml.host.cs.
     NavigationBar provides page-level back navigation. -->
<Page x:Class="TaskFlow.UI.Views.Shell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Pattern: NavigationBar — provides back button and page title. -->
        <utu:NavigationBar Grid.Row="0"
                           Content="TaskFlow" />

        <!-- Pattern: Content region — nested pages render here. -->
        <Grid Grid.Row="1">
            <uen:NavigationView />
        </Grid>

        <!-- Pattern: TabBar — main navigation tabs.
             uen:Region.Name must match route names from RegisterRoutes. -->
        <utu:TabBar Grid.Row="2"
                    uen:Region.Attached="true">

            <utu:TabBarItem Content="Tasks"
                            uen:Navigation.Request="Main/TodoItemList">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE73A;" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>

            <utu:TabBarItem Content="Categories"
                            uen:Navigation.Request="Main/CategoryList">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE8FD;" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>

            <utu:TabBarItem Content="Settings"
                            uen:Navigation.Request="Settings">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
        </utu:TabBar>
    </Grid>
</Page>
