<!-- Pattern: MainPage — tab container / landing page.
     Hosts the NavigationView for nested route content (TodoItemList, CategoryList, etc.).
     This page is mapped to MainModel in RegisterRoutes as the default nested container. -->
<Page x:Class="TaskFlow.UI.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI">

    <!-- Pattern: NavigationView renders child route pages. -->
    <Grid>
        <uen:NavigationView />
    </Grid>
</Page>
