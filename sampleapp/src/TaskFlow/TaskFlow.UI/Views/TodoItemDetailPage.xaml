<!-- ═══════════════════════════════════════════════════════════════
     Pattern: TodoItemDetailPage — detail view with entity data and actions.
     
     Key patterns:
     1. DataViewMap injects TodoItem into TodoItemDetailModel via navigation
     2. TodoItem property displays entity fields (read-only bindings)
     3. IState<bool> IsCompleted enables toggle via CheckBox
     4. Command buttons for ToggleComplete, Delete, GoBack
     ═══════════════════════════════════════════════════════════════ -->
<Page x:Class="TaskFlow.UI.Views.TodoItemDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Padding="16"
          RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Pattern: Header with back button. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding GoBack}"
                    Style="{StaticResource TextButtonStyle}" />

            <TextBlock Grid.Column="1"
                       Text="Task Details"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center" />
        </Grid>

        <!-- Pattern: Entity detail card — binds to TodoItem property on model. -->
        <utu:Card Grid.Row="1">
            <StackPanel Spacing="12" Padding="16">
                <TextBlock Text="{Binding TodoItem.Title}"
                           Style="{StaticResource HeadlineSmallTextBlockStyle}" />

                <TextBlock Text="{Binding TodoItem.Description}"
                           Style="{StaticResource BodyMediumTextBlockStyle}"
                           TextWrapping="Wrap"
                           Opacity="0.8" />

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Priority"
                                   Style="{StaticResource LabelSmallTextBlockStyle}"
                                   Opacity="0.6" />
                        <TextBlock Text="{Binding TodoItem.DisplayPriority}"
                                   Style="{StaticResource BodyLargeTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Category"
                                   Style="{StaticResource LabelSmallTextBlockStyle}"
                                   Opacity="0.6" />
                        <TextBlock Text="{Binding TodoItem.CategoryName}"
                                   Style="{StaticResource BodyLargeTextBlockStyle}" />
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Status"
                                   Style="{StaticResource LabelSmallTextBlockStyle}"
                                   Opacity="0.6" />
                        <TextBlock Text="{Binding TodoItem.DisplayStatus}"
                                   Style="{StaticResource BodyLargeTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Due Date"
                                   Style="{StaticResource LabelSmallTextBlockStyle}"
                                   Opacity="0.6" />
                        <TextBlock Text="{Binding TodoItem.DueDate}"
                                   Style="{StaticResource BodyLargeTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </utu:Card>

        <!-- Pattern: Completion toggle — binds to IState<bool> IsCompleted. -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Top">
            <CheckBox Content="Mark as completed"
                      IsChecked="{Binding IsCompleted, Mode=TwoWay}" />
        </StackPanel>

        <!-- Pattern: Action buttons — bound to MVUX auto-generated commands. -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Right">
            <Button Content="Toggle Complete"
                    Command="{Binding ToggleComplete}"
                    Style="{StaticResource FilledTonalButtonStyle}" />
            <Button Content="Delete"
                    Command="{Binding Delete}"
                    Style="{StaticResource OutlinedButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
