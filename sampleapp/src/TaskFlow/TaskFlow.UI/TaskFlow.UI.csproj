<!-- Pattern: Uno Platform cross-platform UI project using Uno.Sdk.
     Targets all platforms: Web (WASM), Android, iOS, macOS, Windows, Desktop.
     Uses MVUX pattern (not MVVM) for reactive state management.
     Calls Gateway (YARP) via Kiota-generated HTTP client — never calls API directly. -->
<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-browserwasm;net10.0-android;net10.0-ios;net10.0-maccatalyst;net10.0-windows10.0.26100;net10.0-desktop</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>TaskFlow.UI</RootNamespace>
    <ApplicationTitle>TaskFlow</ApplicationTitle>
    <ApplicationId>com.taskflow</ApplicationId>
    <UnoFeatures>
      Material;
      Extensions;
      Toolkit;
      MVUX;
      Hosting;
      Authentication;
      Configuration;
      Http;
      Localization;
      Logging;
      Navigation;
      Serialization;
      Storage;
      ThemeService;
    </UnoFeatures>
  </PropertyGroup>

  <ItemGroup>
    <!-- ═══ Kiota HTTP client generation ═══ -->
    <PackageReference Include="Microsoft.Kiota.Abstractions" />
    <PackageReference Include="Microsoft.Kiota.Http.HttpClientLibrary" />
    <PackageReference Include="Microsoft.Kiota.Serialization.Json" />
    <!-- ═══ Cross-model messaging ═══ -->
    <PackageReference Include="CommunityToolkit.Mvvm" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pattern: App settings are embedded resources for cross-platform access. -->
    <EmbeddedResource Include="appsettings.json" />
    <EmbeddedResource Include="appsettings.development.json" />
  </ItemGroup>
</Project>
