<!-- Pattern: Bootstrapper is a shared library referenced by ALL host projects (API, Scheduler, Functions, Tests).
     Contains centralized DI registration — ensures consistent wiring across all hosts. -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>TaskFlow.Bootstrapper</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Application\TaskFlow.Application.Services\TaskFlow.Application.Services.csproj" />
    <ProjectReference Include="..\..\Application\TaskFlow.Application.MessageHandlers\TaskFlow.Application.MessageHandlers.csproj" />
    <ProjectReference Include="..\..\Infrastructure\TaskFlow.Infrastructure.Repositories\TaskFlow.Infrastructure.Repositories.csproj" />
    <ProjectReference Include="..\..\Infrastructure\TaskFlow.Infrastructure.Notification\TaskFlow.Infrastructure.Notification.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EF.Host" />
    <PackageReference Include="EF.Common" />
    <PackageReference Include="ZiggyCreatures.FusionCache" />
    <PackageReference Include="ZiggyCreatures.FusionCache.Serialization.SystemTextJson" />
    <PackageReference Include="ZiggyCreatures.FusionCache.Backplane.StackExchangeRedis" />
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Microsoft.Extensions.Azure" />
  </ItemGroup>
</Project>
