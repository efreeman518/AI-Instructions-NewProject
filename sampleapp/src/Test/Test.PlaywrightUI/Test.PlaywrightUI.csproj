<!-- Pattern: Test.PlaywrightUI — Playwright E2E browser tests.
     Uses Microsoft.Playwright.MSTest for browser automation.
     Tests run against a live gateway URL (local or CI).
     Each test gets its own BrowserContext for isolation. -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Test.PlaywrightUI</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" />
    <PackageReference Include="Microsoft.Playwright.MSTest" />
    <PackageReference Include="coverlet.collector" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pattern: No project references needed — Playwright tests are pure HTTP/browser tests
         that interact with the running application via its URL, not its internals. -->
    <None Update="appsettings-playwright.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
