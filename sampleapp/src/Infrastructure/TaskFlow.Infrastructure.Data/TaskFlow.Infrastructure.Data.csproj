<!-- Pattern: Infrastructure holds DbContexts, EF configurations, interceptors.
     This is the data-layer foundation; repositories are in a separate project. -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Infrastructure</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Application\TaskFlow.Application.Contracts\TaskFlow.Application.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Provides: EntityBaseConfiguration<T>, RepositoryBase -->
    <PackageReference Include="EF.Data" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
  </ItemGroup>
</Project>
