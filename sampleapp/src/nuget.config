<?xml version="1.0" encoding="utf-8"?>
<!-- Pattern: nuget.config at solution root for package source management.
     Private feeds go here; clear inherited sources to avoid surprise resolution. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Pattern: Private NuGet feed for shared infrastructure packages
         (EF.Domain, EF.Data, etc.) -->
    <add key="PrivateFeed" value="https://pkgs.dev.azure.com/your-org/_packaging/your-feed/nuget/v3/index.json" />
  </packageSources>
</configuration>
