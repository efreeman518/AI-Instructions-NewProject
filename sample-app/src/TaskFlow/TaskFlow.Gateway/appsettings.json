{
  "AppName": "TaskFlow.Gateway",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "taskflow-api",
        "Match": {
          "Path": "api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "taskflow-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://taskflowapi"
          }
        }
      }
    }
  }
}
