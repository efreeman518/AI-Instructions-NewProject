<Page x:Class="TaskFlow.UI.Views.CategoryEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navigation bar with back and save -->
        <utu:NavigationBar Grid.Row="0"
                           Content="{Binding PageTitle}">
            <utu:NavigationBar.MainCommand>
                <AppBarButton Command="{Binding Cancel}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Back" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.MainCommand>
            <utu:NavigationBar.PrimaryCommands>
                <AppBarButton Label="Save"
                              Command="{Binding Save}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Save" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.PrimaryCommands>
        </utu:NavigationBar>

        <!-- Edit form -->
        <ScrollViewer Grid.Row="1"
                      Padding="16">
            <StackPanel Spacing="20"
                        MaxWidth="600"
                        HorizontalAlignment="Stretch">

                <!-- Name -->
                <TextBox Header="Name"
                         PlaceholderText="Enter category name"
                         Text="{Binding Item.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Description -->
                <TextBox Header="Description"
                         PlaceholderText="Enter category description (optional)"
                         Text="{Binding Item.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80" />

                <!-- Color Hex -->
                <TextBox Header="Color (hex)"
                         PlaceholderText="#4CAF50"
                         Text="{Binding Item.ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="7" />

                <!-- Display Order -->
                <muxc:NumberBox xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                                Header="Display Order"
                                Value="{Binding Item.DisplayOrder, Mode=TwoWay}"
                                Minimum="0"
                                SpinButtonPlacementMode="Inline" />

                <!-- Is Active -->
                <ToggleSwitch Header="Active"
                              IsOn="{Binding Item.IsActive, Mode=TwoWay}" />

                <!-- Action buttons -->
                <Grid ColumnSpacing="12"
                      Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Cancel"
                            Command="{Binding Cancel}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource OutlinedButtonStyle}" />

                    <Button Grid.Column="1"
                            Content="Save"
                            Command="{Binding Save}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource FilledButtonStyle}" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
