<Page x:Class="TaskFlow.UI.Views.TodoItemDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navigation bar with back and edit -->
        <utu:NavigationBar Grid.Row="0"
                           Content="Task Details">
            <utu:NavigationBar.MainCommand>
                <AppBarButton Command="{Binding GoBack}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Back" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.MainCommand>
            <utu:NavigationBar.PrimaryCommands>
                <AppBarButton Label="Delete"
                              Click="OnDeleteClick">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Edit"
                              Command="{Binding EditItem}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Edit" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.PrimaryCommands>
        </utu:NavigationBar>

        <!-- Detail content -->
        <uer:FeedView Grid.Row="1"
                      Source="{Binding CurrentItem}">
            <uer:FeedView.ValueTemplate>
                <DataTemplate>
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="16">

                            <!-- Title -->
                            <TextBlock Text="{Binding Data.Title}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />

                            <!-- Status & Priority -->
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Border Background="{ThemeResource SystemAccentColorDark2}"
                                        CornerRadius="12"
                                        Padding="12,6">
                                    <TextBlock Text="{Binding Data.StatusDisplay}"
                                               FontSize="13"
                                               Foreground="White" />
                                </Border>
                                <Border Background="{ThemeResource SystemAccentColorDark1}"
                                        CornerRadius="12"
                                        Padding="12,6">
                                    <TextBlock Text="{Binding Data.PriorityDisplay}"
                                               FontSize="13"
                                               Foreground="White" />
                                </Border>
                            </StackPanel>

                            <!-- Description -->
                            <TextBlock Text="{Binding Data.Description}"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       Opacity="0.8" />

                            <!-- Info rows -->
                            <Grid ColumnSpacing="16" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Category" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Data.CategoryName}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Assigned To" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Data.AssignedToName}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Team" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Data.TeamName}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Comments" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Data.CommentCount}" />
                            </Grid>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,16,0,0">
                                <Button Content="Start"
                                        Command="{Binding StartItem}"
                                        Style="{StaticResource FilledButtonStyle}" />
                                <Button Content="Complete"
                                        Command="{Binding CompleteItem}"
                                        Style="{StaticResource FilledTonalButtonStyle}" />
                                <Button Content="Block"
                                        Command="{Binding BlockItem}"
                                        Style="{StaticResource OutlinedButtonStyle}" />
                                <Button Content="Unblock"
                                        Command="{Binding UnblockItem}"
                                        Style="{StaticResource OutlinedButtonStyle}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>
            </uer:FeedView.ValueTemplate>
        </uer:FeedView>
    </Grid>
</Page>
