<Page x:Class="TaskFlow.UI.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content region for nested pages -->
        <Grid Grid.Row="0" uen:Region.Attached="True" />

        <!-- Bottom tab bar -->
        <utu:TabBar Grid.Row="1"
                     Style="{StaticResource BottomTabBarStyle}">
            <utu:TabBarItem uen:Region.Name="Home"
                            Content="Home">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="TodoItems"
                            Content="Tasks">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="List" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Categories"
                            Content="Categories">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="Folder" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Tags"
                            Content="Tags">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="Tag" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Teams"
                            Content="Teams">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="People" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
        </utu:TabBar>
    </Grid>
</Page>
