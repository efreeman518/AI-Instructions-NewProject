<Page x:Class="TaskFlow.UI.Views.TeamListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <utu:NavigationBar Grid.Row="0"
                           Content="Teams">
            <utu:NavigationBar.PrimaryCommands>
                <AppBarButton Label="New"
                              Command="{Binding CreateItem}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Add" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.PrimaryCommands>
        </utu:NavigationBar>

        <RefreshContainer Grid.Row="1"
                          RefreshRequested="OnRefreshRequested">
        <uer:FeedView Source="{Binding Items}">
            <uer:FeedView.ValueTemplate>
                <DataTemplate>
                    <muxc:ItemsRepeater ItemsSource="{Binding Data}"
                                        Margin="16,0">
                        <muxc:ItemsRepeater.Layout>
                            <muxc:StackLayout Spacing="8" />
                        </muxc:ItemsRepeater.Layout>
                        <muxc:ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:Card Padding="16"
                                          uen:Navigation.Request="TeamEdit"
                                          uen:Navigation.Data="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="13"
                                                       Opacity="0.6"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <SymbolIcon Symbol="People" RenderTransformOrigin="0.5,0.5">
                                                    <SymbolIcon.RenderTransform>
                                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
                                                    </SymbolIcon.RenderTransform>
                                                </SymbolIcon>
                                                <TextBlock Text="{Binding MemberCount}"
                                                           FontSize="12"
                                                           Opacity="0.5" />
                                                <TextBlock Text="members"
                                                           FontSize="12"
                                                           Opacity="0.5" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Delete button -->
                                        <Button Grid.Column="1"
                                                Click="OnDeleteClick"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource TextButtonStyle}"
                                                Padding="8">
                                            <SymbolIcon Symbol="Delete" />
                                        </Button>
                                    </Grid>
                                </utu:Card>
                            </DataTemplate>
                        </muxc:ItemsRepeater.ItemTemplate>
                    </muxc:ItemsRepeater>
                </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
                <DataTemplate>
                    <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  Margin="0,48" />
                </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.NoneTemplate>
                <DataTemplate>
                    <TextBlock Text="No teams found"
                               HorizontalAlignment="Center"
                               Opacity="0.5"
                               Margin="0,48" />
                </DataTemplate>
            </uer:FeedView.NoneTemplate>
        </uer:FeedView>
        </RefreshContainer>
    </Grid>
</Page>
