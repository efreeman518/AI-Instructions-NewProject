<Page x:Class="TaskFlow.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <utu:NavigationBar Grid.Row="0"
                           Content="Settings">
            <utu:NavigationBar.MainCommand>
                <AppBarButton Command="{Binding GoBack}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Back" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.MainCommand>
        </utu:NavigationBar>

        <ScrollViewer Grid.Row="1"
                      Padding="16">
            <StackPanel Spacing="24">

                <!-- App Info -->
                <StackPanel Spacing="8">
                    <TextBlock Text="About"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <utu:Card Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="App:"
                                           FontWeight="SemiBold"
                                           Width="80" />
                                <uer:FeedView Source="{Binding AppTitle}">
                                    <uer:FeedView.ValueTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Data}" />
                                        </DataTemplate>
                                    </uer:FeedView.ValueTemplate>
                                </uer:FeedView>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Version:"
                                           FontWeight="SemiBold"
                                           Width="80" />
                                <uer:FeedView Source="{Binding Version}">
                                    <uer:FeedView.ValueTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Data}" />
                                        </DataTemplate>
                                    </uer:FeedView.ValueTemplate>
                                </uer:FeedView>
                            </StackPanel>
                        </StackPanel>
                    </utu:Card>
                </StackPanel>

                <!-- Preferences placeholder -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Preferences"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <utu:Card Padding="16">
                        <TextBlock Text="Theme and notification preferences coming soon."
                                   Opacity="0.6" />
                    </utu:Card>
                </StackPanel>

                <!-- Account -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Account"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <Button Content="Sign Out"
                            Command="{Binding Logout}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource OutlinedButtonStyle}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
