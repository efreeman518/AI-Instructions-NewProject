<Page x:Class="TaskFlow.UI.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Style="{StaticResource TaskFlowPageStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navigation bar -->
        <utu:NavigationBar Grid.Row="0"
                           Content="TaskFlow">
            <utu:NavigationBar.PrimaryCommands>
                <AppBarButton Label="Settings"
                              uen:Navigation.Request="Settings">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.PrimaryCommands>
        </utu:NavigationBar>

        <!-- Dashboard content -->
        <ScrollViewer Grid.Row="1"
                      Padding="16">
            <StackPanel Spacing="24">

                <!-- Welcome section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Dashboard"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Your task overview"
                               FontSize="14"
                               Opacity="0.7" />
                </StackPanel>

                <!-- Recent items -->
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Recent Tasks"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Content="View All"
                                HorizontalAlignment="Right"
                                Command="{Binding ViewAllTodoItems}"
                                Style="{StaticResource TextButtonStyle}" />
                    </Grid>

                    <uer:FeedView Source="{Binding RecentItems}">
                        <uer:FeedView.ValueTemplate>
                            <DataTemplate>
                                <muxc:ItemsRepeater ItemsSource="{Binding Data}"
                                                    uen:Navigation.Request="TodoItemDetail"
                                                    uen:Navigation.Data="{Binding Data}">
                                    <muxc:ItemsRepeater.Layout>
                                        <muxc:StackLayout Spacing="8" />
                                    </muxc:ItemsRepeater.Layout>
                                    <muxc:ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <utu:Card Padding="16">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock Text="{Binding StatusDisplay}"
                                                                   FontSize="12"
                                                                   Opacity="0.7" />
                                                        <TextBlock Text="{Binding PriorityDisplay}"
                                                                   FontSize="12"
                                                                   Opacity="0.7" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </utu:Card>
                                        </DataTemplate>
                                    </muxc:ItemsRepeater.ItemTemplate>
                                </muxc:ItemsRepeater>
                            </DataTemplate>
                        </uer:FeedView.ValueTemplate>
                        <uer:FeedView.ProgressTemplate>
                            <DataTemplate>
                                <ProgressRing IsActive="True"
                                              HorizontalAlignment="Center"
                                              Margin="0,32" />
                            </DataTemplate>
                        </uer:FeedView.ProgressTemplate>
                        <uer:FeedView.NoneTemplate>
                            <DataTemplate>
                                <TextBlock Text="No tasks yet. Create your first task!"
                                           HorizontalAlignment="Center"
                                           Opacity="0.5"
                                           Margin="0,32" />
                            </DataTemplate>
                        </uer:FeedView.NoneTemplate>
                    </uer:FeedView>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
