<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TaskFlow brand color palette — Material Design overrides -->

    <!-- Primary -->
    <Color x:Key="PrimaryColor">#1976D2</Color>
    <Color x:Key="PrimaryDarkColor">#1565C0</Color>
    <Color x:Key="PrimaryLightColor">#42A5F5</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>

    <!-- Secondary -->
    <Color x:Key="SecondaryColor">#26A69A</Color>
    <Color x:Key="SecondaryDarkColor">#00897B</Color>
    <Color x:Key="OnSecondaryColor">#FFFFFF</Color>

    <!-- Error -->
    <Color x:Key="ErrorColor">#D32F2F</Color>
    <Color x:Key="OnErrorColor">#FFFFFF</Color>

    <!-- Surface -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="OnSurfaceColor">#1C1B1F</Color>
    <Color x:Key="SurfaceVariantColor">#F5F5F5</Color>

    <!-- Background -->
    <Color x:Key="BackgroundColor">#FAFAFA</Color>
    <Color x:Key="OnBackgroundColor">#1C1B1F</Color>

    <!-- Outline -->
    <Color x:Key="OutlineColor">#79747E</Color>

    <!-- Custom status colors for todo items -->
    <Color x:Key="StatusNotStartedColor">#9E9E9E</Color>
    <Color x:Key="StatusInProgressColor">#1976D2</Color>
    <Color x:Key="StatusCompletedColor">#4CAF50</Color>
    <Color x:Key="StatusBlockedColor">#FF9800</Color>
    <Color x:Key="StatusCancelledColor">#D32F2F</Color>
    <Color x:Key="StatusArchivedColor">#607D8B</Color>

    <!-- Priority colors -->
    <Color x:Key="PriorityCriticalColor">#D32F2F</Color>
    <Color x:Key="PriorityHighColor">#FF9800</Color>
    <Color x:Key="PriorityMediumColor">#FFC107</Color>
    <Color x:Key="PriorityLowColor">#4CAF50</Color>
    <Color x:Key="PriorityMinimalColor">#9E9E9E</Color>

</ResourceDictionary>
