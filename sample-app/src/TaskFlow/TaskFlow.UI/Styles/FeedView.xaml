<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:uer="using:Uno.Extensions.Reactive.UI">

    <!-- FeedView default templates — loading, error, empty states -->

    <DataTemplate x:Key="DefaultFeedViewProgressTemplate">
        <ProgressRing IsActive="True"
                      Width="48"
                      Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,48" />
    </DataTemplate>

    <DataTemplate x:Key="DefaultFeedViewNoneTemplate">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Margin="0,48">
            <TextBlock Text="No data available"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Opacity="0.5" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DefaultFeedViewErrorTemplate">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Margin="0,48">
            <SymbolIcon Symbol="ReportHacked" Opacity="0.5" />
            <TextBlock Text="Something went wrong"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Opacity="0.5" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
