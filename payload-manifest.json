{
    "version": "1.3",
    "description": "Runtime payload installed into consumer app repositories.",
    "instructionsRoot": ".instructions",
    "instructionFiles": [
        "README.md",
        "CLAUDE.md",
        "START-AI.md",
        "phase-load-packs.json",
        "_manifest.json",
        "payload-manifest.json"
    ],
    "instructionDirectories": [
        "ai",
        "patterns",
        "schemas",
        "skills",
        "support",
        "templates",
        "scripts"
    ],
    "rootPlacements": [
        {
            "source": "AGENTS.md",
            "destination": "AGENTS.md",
            "requiredUnless": "instructions-only"
        },
        {
            "source": ".claude/commands",
            "destination": ".claude/commands",
            "requiredUnless": "instructions-only"
        },
        {
            "source": ".github/agents",
            "destination": ".github/agents",
            "requiredUnless": "instructions-only"
        }
    ],
    "validationScripts": [
        "scripts/configure-ef-packages-feed.py",
        "scripts/preflight-installed.py",
        "scripts/run-final-scaffold-check.py",
        "scripts/setup-local.py",
        "scripts/validate-domain-spec.py",
        "scripts/validate-resource-impl.py",
        "scripts/validate-ef-packages-feed.py",
        "scripts/validate-handoff.py",
        "scripts/validate-implementation-plan.py",
        "scripts/validate-scaffold-output.py"
    ],
    "authorOnly": [
        ".github/workflows",
        ".github/copilot-instructions.md",
        ".githooks",
        ".vscode",
        ".venv",
        "tests",
        ".gitignore"
    ],
    "postInstallCheck": ".instructions/scripts/preflight-installed.py"
}
